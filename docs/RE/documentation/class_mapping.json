        "bStateReady": "Ready state flag",
        "context": "Activity context",
        "currentCanvas": "Current z (Canvas) instance",
        "currentDisplayable": "Current bv (Displayable) instance",
        "midlet": "bh (MIDlet) instance",
        "midletview": "an (SurfaceView) instance"
      },
      "key_methods": ["onCreate", "run", "getResourceAsStream", "gc"],
